{
  "openapi": "3.1.0",
  "info": {
    "title": "UCOB API Specs",
    "version": "1.0.0",
    "description": "API documentation for the Used Cooking Oil Buying & Selling Platform. Uses HTTP-only cookies for authentication and Signed URLs for file uploads."
  },
  "servers": [
    {
      "url": "https://a495f79c-0188-400e-9a7e-ac496d5c2c46.mock.pstmn.io",
      "description": "Mock Server (Postman)"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/users": {
      "post": {
        "summary": "Register User",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "example": {
                "first_name": "Ucup",
                "last_name": "Surucup",
                "email": "ucup@xyz.com",
                "password": "mypassword123"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "success": true,
                      "code": 201,
                      "data": {
                        "message": "user successfully created"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login User",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "email": "ucup@xyz.com",
                "password": "mypassword123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "headers": {
              "Set-Cookie": {
                "description": "HTTP-only session cookie",
                "schema": {
                  "type": "string",
                  "example": "token=abc123xyz; HttpOnly; Path=/"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "success": true,
                      "code": 200,
                      "data": {
                        "first_name": "Ucup",
                        "last_name": "Surucup",
                        "email": "ucup@xyz.com",
                        "role": "USER"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/users/me": {
      "get": {
        "summary": "Get Current Profile",
        "tags": ["User"],
        "responses": {
          "200": {
            "description": "User profile data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/uploads/signed-url": {
      "post": {
        "summary": "Request Signed Upload URL",
        "tags": ["Utility"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "transaction_type": {
                    "type": "string",
                    "enum": ["BUY", "SELL"]
                  },
                  "content_type": {
                    "type": "string",
                    "example": "image/jpeg"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signed URL generated",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "code": 200,
                  "data": {
                    "upload_url": "https://storage.googleapis.com/...",
                    "public_url": "https://storage.googleapis.com/uploads/sell/photo.jpg"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sell-requests": {
      "post": {
        "summary": "Submit Sell Request",
        "tags": ["Sell"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SellRequestForm"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Request submitted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "My Sell History",
        "tags": ["Sell"],
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "example": 0
            }
          },
          {
            "name": "take",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "example": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of sell requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                },
                "example": {
                  "success": true,
                  "code": 200,
                  "data": [
                    {
                      "id": 101,
                      "quantity_liter": 12.5,
                      "status": "PENDING",
                      "created_at": "2026-04-09T10:00:00Z"
                    }
                  ],
                  "meta": {
                    "skip": 0,
                    "take": 10,
                    "total": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    "/buy-requests": {
      "post": {
        "summary": "Submit Buy Request",
        "tags": ["Buy"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BuyRequestForm"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Request submitted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "My Buy History",
        "tags": ["Buy"],
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "example": 0
            }
          },
          {
            "name": "take",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "example": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of buy requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                },
                "example": {
                  "success": true,
                  "code": 200,
                  "data": [
                    {
                      "id": 201,
                      "quantity_liter": 5.0,
                      "status": "ACCEPTED",
                      "created_at": "2026-04-08T15:00:00Z"
                    }
                  ],
                  "meta": {
                    "skip": 0,
                    "take": 10,
                    "total": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/sell-requests": {
      "get": {
        "summary": "Dashboard: All Sell Requests",
        "tags": ["Admin"],
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "example": 0
            }
          },
          {
            "name": "take",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "example": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "All users' sell requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                },
                "example": {
                  "success": true,
                  "code": 200,
                  "data": [
                    {
                      "id": 101,
                      "user": {
                        "id": 1,
                        "first_name": "Ucup"
                      },
                      "quantity_liter": 12.5,
                      "status": "PENDING"
                    }
                  ],
                  "meta": {
                    "skip": 0,
                    "take": 10,
                    "total": 150
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/sell-requests/{id}/verify": {
      "patch": {
        "summary": "Verify Sell Request",
        "tags": ["Admin"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "example": 101 }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["ACCEPTED", "REJECTED"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/buy-requests": {
      "get": {
        "summary": "Dashboard: All Buy Requests",
        "tags": ["Admin"],
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "example": 0
            }
          },
          {
            "name": "take",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "example": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "All users' buy requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                },
                "example": {
                  "success": true,
                  "code": 200,
                  "data": [
                    {
                      "id": 201,
                      "user": {
                        "id": 2,
                        "first_name": "Budi"
                      },
                      "quantity_liter": 5.0,
                      "status": "PENDING"
                    }
                  ],
                  "meta": {
                    "skip": 0,
                    "take": 10,
                    "total": 80
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/buy-requests/{id}/verify": {
      "patch": {
        "summary": "Verify Buy Request",
        "tags": ["Admin"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "example": 201 }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["ACCEPTED", "REJECTED"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["first_name", "email", "password"],
        "properties": {
          "first_name": { "type": "string", "example": "Ucup" },
          "last_name": { "type": "string", "example": "Surucup" },
          "email": {
            "type": "string",
            "format": "email",
            "example": "ucup@xyz.com"
          },
          "password": { "type": "string", "example": "mypassword123" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "ucup@xyz.com"
          },
          "password": { "type": "string", "example": "mypassword123" }
        }
      },
      "SellRequestForm": {
        "type": "object",
        "required": ["quantity_liter", "pickup_address", "photo_url"],
        "properties": {
          "quantity_liter": { "type": "number", "example": 12.5 },
          "pickup_address": {
            "type": "string",
            "example": "Jl. Mawar No. 12, Jakarta"
          },
          "photo_url": {
            "type": "string",
            "example": "https://storage.googleapis.com/uploads/sell/photo.jpg"
          }
        }
      },
      "BuyRequestForm": {
        "type": "object",
        "required": ["quantity_liter", "delivery_address", "payment_proof_url"],
        "properties": {
          "quantity_liter": { "type": "number", "example": 5.0 },
          "delivery_address": {
            "type": "string",
            "example": "Jl. Melati No. 5, Bandung"
          },
          "payment_proof_url": {
            "type": "string",
            "example": "https://storage.googleapis.com/uploads/buy/proof.jpg"
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "code": { "type": "integer", "example": 200 },
          "data": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "example": "success"
              }
            }
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "code": { "type": "integer", "example": 200 },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "integer", "example": 1 },
              "first_name": {
                "type": "string",
                "example": "Ucup"
              },
              "last_name": {
                "type": "string",
                "example": "Surucup"
              },
              "email": {
                "type": "string",
                "example": "ucup@xyz.com"
              },
              "role": {
                "type": "string",
                "enum": ["ADMIN", "USER"],
                "example": "USER"
              }
            }
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "code": { "type": "integer", "example": 200 },
          "data": { "type": "array", "items": { "type": "object" } },
          "meta": {
            "type": "object",
            "properties": {
              "skip": { "type": "integer", "example": 0 },
              "take": { "type": "integer", "example": 10 },
              "total": { "type": "integer", "example": 100 }
            }
          }
        }
      },
      "ErrorSchema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "code": { "type": "integer", "example": 400 },
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "example": "error message"
              },
              "kind": {
                "type": "string",
                "example": "BadRequest"
              }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid Input",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorSchema"
            },
            "example": {
              "success": false,
              "code": 400,
              "error": {
                "message": "invalid input",
                "kind": "BadRequest"
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Not Logged In",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorSchema"
            },
            "example": {
              "success": false,
              "code": 401,
              "error": {
                "message": "session expired",
                "kind": "Unauthorized"
              }
            }
          }
        }
      },
      "Conflict": {
        "description": "Resource Already Exists",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorSchema"
            },
            "example": {
              "success": false,
              "code": 409,
              "error": {
                "message": "email already exists",
                "kind": "ResourceConflict"
              }
            }
          }
        }
      }
    }
  }
}
